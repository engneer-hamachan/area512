# clangd (coc-clangd) config for this ESP-IDF / xtensa-gcc project.
#
# The build uses xtensa-esp32s3-elf-gcc, but clangd parses with its bundled
# clang. clang doesn't recognise some gcc-only flags, which surface as
# editor-only warnings even though the gcc build is clean. Strip them here.
#
# The matching half of the fix (telling clangd to pull the cross-gcc's system
# + C++ standard headers and predefined macros) is the --query-driver flag in
# coc-settings.json — without it, <vector>/<cstdint> etc. won't resolve in .cpp.

CompileFlags:
  # build/compile_commands.json is generated by idf.py.
  CompilationDatabase: build
  Add:
    - -Wno-unknown-warning-option
    # clangd has no xtensa backend, so it parses with the host (x86_64) target
    # and leaves __XTENSA__ undefined. That sends ESP-IDF's xtensa/config/core.h
    # down its non-xtensa branch (#include "../hal.h"), which doesn't exist and
    # cascades into dozens of editor-only errors. Define it so the correct
    # <xtensa/hal.h> branch is taken, matching the gcc build.
    - -D__XTENSA__=1
    - -D__XTENSA_EL__=1
  Remove:
    - -fno-tree-switch-conversion
    - -fstrict-volatile-bitfields
    - -fno-shrink-wrap
    - -fno-tree-loop-distribute-patterns
    - -mlongcalls
    - -mtext-section-literals
    - -fmacro-prefix-map=*

Diagnostics:
  # All editor diagnostics disabled project-wide.
  Suppress: '*'
  ClangTidy:
    Remove:
      - "*"
